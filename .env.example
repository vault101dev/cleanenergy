# Copy this file to .env and fill in your keys.
# Both are free — sign up takes under a minute.

# NREL API key (powers PVWatts production estimates + Solar Resource irradiance data)
# Get one at: https://developer.nlr.gov/signup/
NREL_API_KEY=your_nrel_api_key_here

# EIA API key (powers state electricity retail rate lookups)
# Get one at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# Required only when running the HTTP server (npm run start:http) for remote
# hosting (Render, Fly.io, etc). This is a shared secret YOU generate — not
# from NREL or EIA — used to require a Bearer token on requests to your
# public /mcp endpoint so random internet traffic can't call your tools and
# burn your NREL/EIA API quota. Generate one with:
#   openssl rand -hex 32
MCP_AUTH_TOKEN=your_own_random_secret_here
