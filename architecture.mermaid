flowchart TB
    subgraph client["Client surfaces"]
        Desktop["Claude Desktop<br/>(.mcpb extension)"]
        Widget["solar-quote-widget.html<br/>(browser, static file)"]
    end

    subgraph transport["Transport"]
        Stdio["stdio<br/>(local process)"]
        HTTP["Streamable HTTP<br/>+ Bearer auth + CORS"]
    end

    subgraph server["clean-energy-mcp server (shared logic)"]
        Index["src/index.ts<br/>(stdio entry)"]
        HttpEntry["src/http.ts<br/>(HTTP entry, hosted on Render)"]
        Tools["src/tools.ts<br/>4 MCP tools"]
    end

    subgraph libs["Data clients"]
        Geo["lib/geocode.ts"]
        Nrel["lib/nrel.ts"]
        Eia["lib/eia.ts"]
    end

    subgraph apis["External APIs"]
        Census["US Census Geocoder"]
        PVWatts["NREL PVWatts + Solar Resource"]
        EIA["EIA Electricity Rates"]
    end

    Desktop -->|stdio| Stdio --> Index
    Widget -->|"fetch() POST /mcp"| HTTP --> HttpEntry
    Index --> Tools
    HttpEntry --> Tools
    Tools --> Geo --> Census
    Tools --> Nrel --> PVWatts
    Tools --> Eia --> EIA

    GitHub["GitHub repo"] -->|push triggers auto-deploy| Render["Render (free web service)"]
    Render -.hosts.-> HttpEntry
